+	/*
+	 * Private transport hook used by git-remote-octo. The URL continues to
+	 * describe the HTTP request while curl connects to Octo's Unix socket.
+	 */
+	unix_socket = getenv("GIT_HTTP_UNIX_SOCKET");
+	if (unix_socket) {
+		if (!*unix_socket)
+			die("GIT_HTTP_UNIX_SOCKET is empty");
+		if (curl_easy_setopt(result, CURLOPT_UNIX_SOCKET_PATH, unix_socket))
+			die("failed to configure HTTP Unix socket");
+	}
+
